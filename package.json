{
  "name": "meendah",
  "main": "expo-router/entry",
  "version": "1.0.3",
  "scripts": {
    "forward:android": "adb forward tcp:5554 tcp:5555",
    "start": "expo start",
    "android": "expo run:android",
    "android:clean": "cd android && ./gradlew clean && if (Test-Path .cxx) { Remove-Item -Recurse -Force .cxx } && if (Test-Path app/build) { Remove-Item -Recurse -Force app/build } && if (Test-Path build) { Remove-Item -Recurse -Force build }",
    "android:dev": "npx expo start --dev-client",
    "build:debug:apk": "npx expo prebuild --platform android && cd android && gradlew assembleDebug && cd ..",
    "build:release:apk": "npx expo prebuild --platform android && cd android && gradlew assembleRelease && cd ..",
    "ios": "expo run:ios",
    "build:android": "eas build --platform android",
    "build:android:preview:apk": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios",
    "build:ios:preview": "eas build --platform ios --profile preview --non-interactive",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.100.11",
    "axios": "^1.16.1",
    "expo": "~55.0.25",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-contacts": "~55.0.14",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.8",
    "expo-glass-effect": "~55.0.11",
    "expo-image": "~55.0.10",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.15",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "i18next": "^26.2.0",
    "libphonenumber-js": "^1.13.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
