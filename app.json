{
  "expo": {
    "name": "meendah",
    "slug": "meendah",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/logo/meendah_english_light.png",
    "scheme": "meendah",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.meendah.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#208AEF",
        "foregroundImage": "./assets/images/logo/meendah_english_light_adaptive.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.meendah.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo/meendah_english_light.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withCallDetection",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Meen Dah to access your contacts to help identify unknown callers and build our community database."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/logo/meendah_english_light.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "extraGradleArguments": [
              "-x",
              "lintVitalAnalyzeRelease"
            ],
            "ndkVersion": "26.1.10909125",
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "92787d93-9e30-438a-a3ef-d556fea2ab07"
      }
    }
  }
}
